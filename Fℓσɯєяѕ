-- Distortion Tools Script (LocalScript)
-- Cria duas Tools no Backpack do jogador

local player = game.Players.LocalPlayer
local backpack = player:WaitForChild("Backpack")

local function getChar()
    return player.Character or player.CharacterAdded:Wait()
end

--------------------------------------------------------------------
-- TOOL 1: Distort Body + Music
--------------------------------------------------------------------

local tool1 = Instance.new("Tool")
tool1.Name = "Flower Distort"
tool1.RequiresHandle = false
tool1.Parent = backpack

local sound = Instance.new("Sound")
sound.SoundId = "rbxassetid://COLOQUE_SEU_AUDIO_ID_AQUI"
sound.Looped = true
sound.Volume = 1
sound.Parent = workspace.CurrentCamera

local running = false
local joints = {}
local original = {}

local function collectJoints(char)
    joints = {}
    original = {}
    for _,v in pairs(char:GetDescendants()) do
        if v:IsA("Motor6D") then
            table.insert(joints,v)
            original[v] = v.C0
        end
    end
end

local function distortLoop(char,humanoid)
    while running do
        if humanoid.MoveDirection.Magnitude > 0 then
            for _,j in pairs(joints) do
                local rx = math.rad(math.random(-15,15))
                local ry = math.rad(math.random(-15,15))
                local rz = math.rad(math.random(-15,15))
                j.C0 = original[j] * CFrame.Angles(rx,ry,rz)
            end
        else
            for j,c0 in pairs(original) do
                if j then
                    j.C0 = c0
                end
            end
        end
        task.wait(0.08)
    end
end

local function startDistort()
    local char = getChar()
    local humanoid = char:WaitForChild("Humanoid")

    collectJoints(char)

    if humanoid:FindFirstChild("BodyHeightScale") then
        humanoid.BodyHeightScale.Value = 1.6
    end

    running = true
    sound:Play()

    task.spawn(function()
        distortLoop(char,humanoid)
    end)
end

local function stopDistort()
    running = false
    sound:Stop()

    local char = player.Character
    if not char then return end

    for j,c0 in pairs(original) do
        if j then
            j.C0 = c0
        end
    end

    local humanoid = char:FindFirstChild("Humanoid")
    if humanoid and humanoid:FindFirstChild("BodyHeightScale") then
        humanoid.BodyHeightScale.Value = 1
    end
end

tool1.Equipped:Connect(startDistort)
tool1.Unequipped:Connect(stopDistort)

--------------------------------------------------------------------
-- TOOL 2: Tall Thin Distortion
--------------------------------------------------------------------

local tool2 = Instance.new("Tool")
tool2.Name = "Flower Form"
tool2.RequiresHandle = false
tool2.Parent = backpack

local running2 = false

local function startForm()
    local char = getChar()
    local humanoid = char:WaitForChild("Humanoid")

    if humanoid:FindFirstChild("BodyHeightScale") then
        humanoid.BodyHeightScale.Value = 2.5
    end

    if humanoid:FindFirstChild("BodyWidthScale") then
        humanoid.BodyWidthScale.Value = 0.3
    end

    if humanoid:FindFirstChild("BodyDepthScale") then
        humanoid.BodyDepthScale.Value = 0.3
    end

    running2 = true

    task.spawn(function()
        while running2 do
            for _,v in pairs(char:GetDescendants()) do
                if v:IsA("Motor6D") then
                    local rx = math.rad(math.random(-25,25))
                    local ry = math.rad(math.random(-25,25))
                    v.C0 = v.C0 * CFrame.Angles(rx,ry,0)
                end
            end
            task.wait(0.1)
        end
    end)
end

local function stopForm()
    running2 = false

    local char = player.Character
    if not char then return end

    local humanoid = char:FindFirstChild("Humanoid")
    if humanoid then
        if humanoid:FindFirstChild("BodyHeightScale") then
            humanoid.BodyHeightScale.Value = 1
        end
        if humanoid:FindFirstChild("BodyWidthScale") then
            humanoid.BodyWidthScale.Value = 1
        end
        if humanoid:FindFirstChild("BodyDepthScale") then
            humanoid.BodyDepthScale.Value = 1
        end
    end
end

tool2.Equipped:Connect(startForm)
tool2.Unequipped:Connect(stopForm)