-- LOG
local logs = {}
local function log(msg)
    table.insert(logs, msg)
    print("[DEOBF]", msg)
end

-- DETECÇÃO
local function extractURL(text)
    return text:match('HttpGet%(%s*"(.-)"%s*%)')
        or text:match("HttpGet%(%s*'(.-)'%s*%)")
end

-- DECODERS
local function decodeEscapes(str)
    return str:gsub("\\(%d%d?%d?)", function(n)
        return string.char(tonumber(n))
    end)
end

local function tryBase64(str)
    local ok, res = pcall(function()
        return HttpService:Base64Decode(str)
    end)
    if ok then return res end
end

-- LIMPEZA
local function cleanCode(code)
    code = code:gsub("%s+", " ")
    code = code:gsub("local _0x%x+", "-- removed var")
    return code
end

-- RENOMEAÇÃO
local function renameVars(code)
    local index = 0
    return code:gsub("local%s+([_%w]+)", function(var)
        index += 1
        return "local var" .. index
    end)
end

-- INDENTAÇÃO
local function indent(code)
    local level = 0
    local result = ""
    for line in code:gmatch("[^\n]+") do
        if line:match("end") then level -= 1 end
        result = result .. string.rep("    ", math.max(level,0)) .. line .. "\n"
        if line:match("then") or line:match("do") then level += 1 end
    end
    return result
end

-- PROCESSAMENTO
local function process(code)
    log("Iniciando processamento...")
    for i = 1, 3 do
        local new = decodeEscapes(code)
        if new ~= code then
            log("Escapes decodificados")
            code = new
        end
        local b64 = tryBase64(code)
        if b64 then
            log("Base64 detectado")
            code = b64
        end
    end
    code = cleanCode(code)
    code = renameVars(code)
    code = indent(code)
    return code
end

-- EXEC
button.MouseButton1Click:Connect(function()
    output.Text = ""
    logs = {}
    local text = input.Text
    local url = extractURL(text)
    if url then
        log("Loadstring detectada")
        local ok, result = pcall(function()
            return game:HttpGet(url)
        end)
        if ok then text = result else
            output.Text = "Erro ao baixar"
            return
        end
    end
    local final = process(text)
    output.Text = final
end)

