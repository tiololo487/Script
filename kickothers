local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local player = Players.LocalPlayer

-- Character
local character, humanoid, hrp

local function updateCharacter()
	character = player.Character or player.CharacterAdded:Wait()
	humanoid = character:WaitForChild("Humanoid")
	hrp = character:WaitForChild("HumanoidRootPart")
end

updateCharacter()
player.CharacterAdded:Connect(updateCharacter)

-- GUI
local gui = Instance.new("ScreenGui")
gui.Parent = player:WaitForChild("PlayerGui")

-- Função pra criar botão arrastável
local function createButton(name, position)
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(0, 140, 0, 50)
	btn.Position = position
	btn.Text = name
	btn.BackgroundColor3 = Color3.fromRGB(30,30,30)
	btn.TextColor3 = Color3.new(1,1,1)
	btn.Parent = gui

	-- Drag
	local dragging = false
	local dragStart, startPos

	btn.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = true
			dragStart = input.Position
			startPos = btn.Position
		end
	end)

	btn.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = false
		end
	end)

	game:GetService("UserInputService").InputChanged:Connect(function(input)
		if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
			local delta = input.Position - dragStart
			btn.Position = UDim2.new(
				startPos.X.Scale,
				startPos.X.Offset + delta.X,
				startPos.Y.Scale,
				startPos.Y.Offset + delta.Y
			)
		end
	end)

	return btn
end

-- Fling
local flingConnection

local function startFling()
	if flingConnection then return end

	flingConnection = RunService.Heartbeat:Connect(function()
		for _, p in pairs(Players:GetPlayers()) do
			if p ~= player and p.Character then
				local targetHRP = p.Character:FindFirstChild("HumanoidRootPart")
				local hum = p.Character:FindFirstChildOfClass("Humanoid")

				if targetHRP and hum and hum.Health > 0 then
					if (hrp.Position - targetHRP.Position).Magnitude < 10 then
						local bv = Instance.new("BodyVelocity")
						bv.Velocity = (targetHRP.Position - hrp.Position).Unit * 15000
						bv.MaxForce = Vector3.new(1e9,1e9,1e9)
						bv.Parent = targetHRP

						game:GetService("Debris"):AddItem(bv, 0.1)
					end
				end
			end
		end
	end)
end

local function stopFling()
	if flingConnection then
		flingConnection:Disconnect()
		flingConnection = nil
	end
end

-- Função de ataque
local cooldown = false

local function attack(animationId)
	if cooldown then return end
	cooldown = true

	local animator = humanoid:FindFirstChildOfClass("Animator")
	if not animator then
		animator = Instance.new("Animator", humanoid)
	end

	local anim = Instance.new("Animation")
	anim.AnimationId = animationId

	local track = animator:LoadAnimation(anim)
	track:Play()

	startFling()

	track.Stopped:Wait()

	stopFling()
	cooldown = false
end

