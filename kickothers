local Players = game:GetService("Players")
local player = Players.LocalPlayer

local tool = Instance.new("Tool")
tool.Name = "Kick Tool"
tool.RequiresHandle = false
tool.Parent = player.Backpack

local scriptTool = Instance.new("LocalScript")
scriptTool.Parent = tool

scriptTool.Source = [[
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Debris = game:GetService("Debris")

local LocalPlayer = Players.LocalPlayer
local tool = script.Parent

local character, humanoid, hrp

local function updateCharacter()
	character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
	humanoid = character:WaitForChild("Humanoid")
	hrp = character:WaitForChild("HumanoidRootPart")
end

updateCharacter()
LocalPlayer.CharacterAdded:Connect(updateCharacter)

local flingActive = false
local connection

local function startFling()
	if flingActive then return end
	flingActive = true

	connection = RunService.Heartbeat:Connect(function()
		for _, p in ipairs(Players:GetPlayers()) do
			if p ~= LocalPlayer and p.Character then
				local oHRP = p.Character:FindFirstChild("HumanoidRootPart")
				local hum = p.Character:FindFirstChildOfClass("Humanoid")

				if oHRP and hum and hum.Health > 0 then
					if (hrp.Position - oHRP.Position).Magnitude < 8 then
						local bv = Instance.new("BodyVelocity")
						bv.Velocity = (oHRP.Position - hrp.Position).Unit * 10000
						bv.MaxForce = Vector3.new(1e9,1e9,1e9)
						bv.Parent = oHRP
						Debris:AddItem(bv, 0.15)
					end
				end
			end
		end
	end)
end

local function stopFling()
	flingActive = false
	if connection then
		connection:Disconnect()
		connection = nil
	end
end

local cooldown = false

tool.Activated:Connect(function()
	if cooldown then return end
	cooldown = true

	local anim = Instance.new("Animation")
	anim.AnimationId = "rbxassetid://127764273000599"

	local track = humanoid:LoadAnimation(anim)
	track:Play()

	startFling()

	track.Stopped:Connect(function()
		stopFling()
		cooldown = false
	end)
end)

tool.Unequipped:Connect(function()
	stopFling()
	cooldown = false
end)
]]

