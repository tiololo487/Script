local Players = game:GetService("Players")
local player = Players.LocalPlayer

-- Função para criar Tool
local function createTool(name, animationId)
	local tool = Instance.new("Tool")
	tool.Name = name
	tool.RequiresHandle = false
	tool.Parent = player:WaitForChild("Backpack")

	local character = player.Character or player.CharacterAdded:Wait()
	local humanoid = character:WaitForChild("Humanoid")
	local hrp = character:WaitForChild("HumanoidRootPart")

	player.CharacterAdded:Connect(function(char)
		character = char
		humanoid = char:WaitForChild("Humanoid")
		hrp = char:WaitForChild("HumanoidRootPart")
	end)

	local flingConnection
	local cooldown = false

	local function startFling()
		if flingConnection then return end

		flingConnection = game:GetService("RunService").Heartbeat:Connect(function()
			for _, p in pairs(Players:GetPlayers()) do
				if p ~= player and p.Character then
					local targetHRP = p.Character:FindFirstChild("HumanoidRootPart")
					local hum = p.Character:FindFirstChildOfClass("Humanoid")

					if targetHRP and hum and hum.Health > 0 then
						local dist = (hrp.Position - targetHRP.Position).Magnitude
						if dist < 10 then
							-- Força mais forte
							local bv = Instance.new("BodyVelocity")
							bv.Velocity = (targetHRP.Position - hrp.Position).Unit * 15000
							bv.MaxForce = Vector3.new(1e9,1e9,1e9)
							bv.Parent = targetHRP

							game:GetService("Debris"):AddItem(bv, 0.1)
						end
					end
				end
			end
		end)
	end

	local function stopFling()
		if flingConnection then
			flingConnection:Disconnect()
			flingConnection = nil
		end
	end

	tool.Activated:Connect(function()
		if cooldown then return end
		cooldown = true

		local animator = humanoid:FindFirstChildOfClass("Animator")
		if not animator then
			animator = Instance.new("Animator", humanoid)
		end

		local anim = Instance.new("Animation")
		anim.AnimationId = animationId

		local track = animator:LoadAnimation(anim)
		track:Play()

		startFling()

		track.Stopped:Wait()

		stopFling()
		cooldown = false
	end)

	tool.Unequipped:Connect(function()
		stopFling()
		cooldown = false
	end)
end

