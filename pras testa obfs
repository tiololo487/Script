<!DOCTYPE html>
<html lang="pt">
<head>
<meta charset="UTF-8">
<title>Lua Deobfuscator</title>
<style>
body {
    background:#111;
    color:#0f0;
    font-family: monospace;
    padding:20px;
}
textarea {
    width:100%;
    height:200px;
    background:#000;
    color:#0f0;
    border:1px solid #0f0;
}
button {
    margin-top:10px;
    padding:10px;
    background:#0f0;
    color:#000;
    border:none;
    cursor:pointer;
}
pre {
    white-space: pre-wrap;
    margin-top:20px;
    background:#000;
    padding:10px;
    border:1px solid #0f0;
}
</style>
</head>
<body>

<h2>Lua WeAreDevs Deobfuscator</h2>

<textarea id="input" placeholder="Cole o script aqui..."></textarea>
<br>
<button onclick="decodeLua()">Deobfuscar</button>

<pre id="output"></pre>

<script>
function decodeEscapeStrings(str) {
    return str.replace(/(\\\d{3})+/g, match => {
        return match.replace(/\\(\d{3})/g, (_, num) => {
            return String.fromCharCode(parseInt(num, 10));
        });
    });
}

function decodeLua() {
    let input = document.getElementById("input").value;

    // decodifica sequências \ddd
    let decoded = decodeEscapeStrings(input);

    // tenta melhorar leitura removendo escapes duplos
    decoded = decoded.replace(/\\\\/g, "\\");

    document.getElementById("output").textContent = decoded;
}
</script>

</body>
</html>