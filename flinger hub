                    if tick() - lastFling < 0.1 then return end
                    lastFling = tick()

                    if not selectedPlayer or not selectedPlayer.Character then return end

                    local char = selectedPlayer.Character
                    local hrp = char:FindFirstChild("HumanoidRootPart")
                    local hum = char:FindFirstChildOfClass("Humanoid")

                    if not hrp or not hum or hum.Health <= 0 then return end

                    TriggerCrashOn(selectedPlayer, 10)

                    -- Fling direto no HRP como backup caso TriggerCrashOn falhe
                    local bv = Instance.new("BodyVelocity")
                    bv.Velocity = Vector3.new(
                        math.random(-1, 1) * 1e6,
                        1e6,
                        math.random(-1, 1) * 1e6
                    )
                    bv.MaxForce = Vector3.new(1e9, 1e9, 1e9)
                    bv.P = 1e9
                    bv.Parent = hrp
                    game:GetService("Debris"):AddItem(bv, 0.05)
                end)

                print("[Annoy] Ativo em: " .. selectedPlayer.Name)
            else
                warn("[Annoy] Nenhum player selecionado!")
                crashAtivo = false
            end
        else
            print("[Annoy] Desativado")
        end
    end
})
