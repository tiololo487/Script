-- pegar bola
local function getBall(character, backpack, serverBalls)
    local tool = backpack:FindFirstChild("SoccerBall")

    if not tool then
        local remote = RS:FindFirstChild("RE")
        if remote and remote:FindFirstChild("1Too1l") then
            pcall(function()
                remote["1Too1l"]:InvokeServer("PickingTools", "SoccerBall")
            end)
        end
    end

    tool = backpack:WaitForChild("SoccerBall", 5)
    if not tool then return nil end

    tool.Parent = character
    local ball = serverBalls:WaitForChild("Soccer" .. player.Name, 5)
    tool.Parent = backpack

    return ball
end

-- fling principal
local function FlingBall(target)
    local character = player.Character or player.CharacterAdded:Wait()
    local humanoid = character:WaitForChild("Humanoid")
    local backpack = player:WaitForChild("Backpack")

    local serverBalls = workspace:WaitForChild("WorkspaceCom"):WaitForChild("001_SoccerBalls")

    running = true

    while running do
        if not target or target.Parent ~= Players then break end

        local tchar = target.Character
        if not tchar then task.wait() continue end

        local troot = tchar:FindFirstChild("HumanoidRootPart")
        local thum = tchar:FindFirstChild("Humanoid")

        if not troot then task.wait() continue end

        local ball = serverBalls:FindFirstChild("Soccer" .. player.Name)
            or getBall(character, backpack, serverBalls)

        if not ball then
            task.wait(0.2)
            continue
        end

        ball.CanCollide = false
        ball.Massless = true
        ball.AssemblyLinearVelocity = Vector3.zero

        pcall(function()
            ball:SetNetworkOwner(player)
        end)

        pcall(function()
            ball.CustomPhysicalProperties = PhysicalProperties.new(0.00001, 0, 0)
        end)

        -- limpar forças
        for _, v in ipairs(ball:GetChildren()) do
            if v:IsA("BodyMover") then
                v:Destroy()
            end
        end

        local bp = Instance.new("BodyPosition")
        bp.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        bp.P = 5e7
        bp.D = 0
        bp.Parent = ball

        local bv = Instance.new("BodyVelocity")
        bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        bv.Parent = ball

        ball.AssemblyAngularVelocity = Vector3.new(1e6,1e6,1e6)

        local start = tick()

        while running and tchar.Parent do
            bp.Position = troot.Position

            bv.Velocity = Vector3.new(
                math.random(-5e7,5e7),
                math.random(-5e7,5e7),
                math.random(-5e7,5e7)
            )

            ball.AssemblyAngularVelocity = Vector3.new(
                math.random(-1e6,1e6),
                math.random(-1e6,1e6),
                math.random(-1e6,1e6)
            )

            if (ball.Position - troot.Position).Magnitude > 6 then
                ball.CFrame = troot.CFrame
            end

            if (thum and thum.Health <= 0)
            or not tchar:IsDescendantOf(workspace)
            or tick() - start > 6 then
                break
            end

            RunService.Heartbeat:Wait()
        end

        bp:Destroy()
        bv:Destroy()

        task.wait(0.1)
    end
end
