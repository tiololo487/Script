    Ball.CanCollide = true
    Ball.Massless = false
    Ball.CustomPhysicalProperties = PhysicalProperties.new(0.01, 0, 0)

    -- LIMPAR
    for _, v in pairs(Ball:GetChildren()) do
        if v:IsA("BodyPosition") 
        or v:IsA("BodyVelocity") 
        or v:IsA("BodyAngularVelocity") then
            v:Destroy()
        end
    end

    -- POSIÇÃO
    local bp = Instance.new("BodyPosition")
    bp.MaxForce = Vector3.new(9e9,9e9,9e9)
    bp.P = 1e6
    bp.D = 100
    bp.Parent = Ball

    -- VELOCIDADE (FLING)
    local bv = Instance.new("BodyVelocity")
    bv.MaxForce = Vector3.new(9e9,9e9,9e9)
    bv.Velocity = Vector3.new(0,0,0)
    bv.Parent = Ball

    -- GIRO
    local bav = Instance.new("BodyAngularVelocity")
    bav.MaxTorque = Vector3.new(9e9,9e9,9e9)
    bav.AngularVelocity = Vector3.new(5000,5000,5000)
    bav.Parent = Ball

    local running = true
    local radius = 6
    local t = 0

    stopOrbit = function()
        running = false
        if bp then bp:Destroy() end
        if bv then bv:Destroy() end
        if bav then bav:Destroy() end
    end

    local connection
    connection = RunService.Heartbeat:Connect(function(dt)
        if not running or not hrp.Parent then
            connection:Disconnect()
            stopOrbit()
            return
        end

        t += dt * 10

        local x = math.sin(t * 3) * radius
        local y = math.cos(t * 5) * 2
        local z = math.cos(t * 3) * radius

        local pos = hrp.Position + Vector3.new(x, y, z)
        bp.Position = pos

        -- FLING DIRECIONAL
        local direction = (pos - Ball.Position).Unit
        bv.Velocity = direction * 600 -- pode aumentar pra 1000 se quiser absurdo
    end)
end


