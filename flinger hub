-- pegar bola (CORRIGIDO DE VERDADE)
local function getBall(player, character, backpack, serverBalls)
    local tool = backpack:FindFirstChild("SoccerBall")

    if not tool then
        local remote = RS:WaitForChild("RE", 5)
        if remote then
            local func = remote:FindFirstChild("1Too1l") -- NÃO MEXE
            if func then
                pcall(function()
                    func:InvokeServer("PickingTools", "SoccerBall")
                end)
            end
        end
    end

    -- ⚠️ ESSENCIAL (esperar vir)
    tool = backpack:WaitForChild("SoccerBall", 5)
    if not tool then return nil end

    -- ⚠️ EQUIPAR (gera a bola)
    tool.Parent = character

    -- ⚠️ ESPERAR A BOLA REAL
    local ball = serverBalls:WaitForChild("Soccer" .. player.Name, 5)

    -- devolver tool
    tool.Parent = backpack

    return ball
end

-- setup (mantive, só ajustei leve)
local function setupBall(ball)
    if not ball then return end

    ball.CanCollide = false
    ball.Massless = true
    ball.AssemblyLinearVelocity = Vector3.zero

    pcall(function()
        ball.CustomPhysicalProperties = PhysicalProperties.new(0.00001, 0, 0)
    end)

    if not ball:FindFirstChild("FlingPower") then
        local bv = Instance.new("BodyVelocity")
        bv.Name = "FlingPower"
        bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        bv.P = math.huge
        bv.Parent = ball
    end
end

local function FlingBall(target)
    local player = Players.LocalPlayer
    local character = player.Character or player.CharacterAdded:Wait()
    local humanoid = character:WaitForChild("Humanoid")
    local backpack = player:WaitForChild("Backpack")

    local serverBalls = workspace:WaitForChild("WorkspaceCom", 5)
    if not serverBalls then return end
    serverBalls = serverBalls:WaitForChild("001_SoccerBalls", 5)
    if not serverBalls then return end

    running = true

    while running do
        if not target or target.Parent ~= Players then break end

        local tchar = target.Character
        if not tchar then task.wait() continue end

        local troot = tchar:FindFirstChild("HumanoidRootPart")
        local thum = tchar:FindFirstChild("Humanoid")

        if not troot then task.wait() continue end

        -- pega bola
        local ball = serverBalls:FindFirstChild("Soccer" .. player.Name)
        if not ball then
            ball = getBall(player, character, backpack, serverBalls)
        end

        if not ball then
            task.wait(0.2)
            continue
        end

        setupBall(ball)
        local bv = ball:FindFirstChild("FlingPower")

        workspace.CurrentCamera.CameraSubject = thum or humanoid

        local start = tick()

        while running and tchar.Parent do
            local vel = troot.AssemblyLinearVelocity
            local predicted = troot.Position + (vel * 0.12)

            -- mantém posicionamento
            ball.CFrame = CFrame.new(predicted)

            -- força real (FLING)
            if bv then
                bv.Velocity = (predicted - ball.Position) * 500
            end

            -- fallback
            if vel.Magnitude < 5 then
                for _, part in ipairs(tchar:GetChildren()) do
                    if part:IsA("BasePart") then
                        ball.CFrame = part.CFrame
                        RunService.Heartbeat:Wait()
                    end
                end
            end

            if (thum and thum.Health <= 0)
            or not tchar:IsDescendantOf(workspace)
            or tick() - start > 6 then
                break
            end

            RunService.Heartbeat:Wait()
        end

        workspace.CurrentCamera.CameraSubject = humanoid
        task.wait(0.1)
    end
end

