local stopOrbit = nil

local function OrbitBallClean()

    local Players = game:GetService("Players")
    local RS = game:GetService("ReplicatedStorage")
    local RunService = game:GetService("RunService")

    local player = Players.LocalPlayer
    local character = player.Character or player.CharacterAdded:Wait()
    local hrp = character:WaitForChild("HumanoidRootPart")
    local backpack = player:WaitForChild("Backpack")

    local ServerBalls = workspace.WorkspaceCom:WaitForChild("001_SoccerBalls")

    -- 🔁 pegar bola
    local function GetBall()
        local name = "Soccer"..player.Name
        local ball = ServerBalls:FindFirstChild(name)

        if not ball then
            RS.RE:FindFirstChild("1Too1l"):InvokeServer("PickingTools", "SoccerBall")
            repeat task.wait() until backpack:FindFirstChild("SoccerBall")
            backpack.SoccerBall.Parent = character
            repeat task.wait() until ServerBalls:FindFirstChild(name)
            ball = ServerBalls:FindFirstChild(name)
        end

        return ball
    end

    local Ball = GetBall()
    if not Ball then return end

    -- ⚙️ física balanceada
    Ball.CanCollide = true
    Ball.Massless = false
    Ball.CustomPhysicalProperties = PhysicalProperties.new(0.0001, 0, 0)

    -- limpar forças
    for _,v in ipairs(Ball:GetChildren()) do
        if v:IsA("BodyMover") then
            v:Destroy()
        end
    end

    -- 🧲 posição estável
    local bp = Instance.new("BodyPosition")
    bp.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    bp.P = 50000
    bp.D = 500
    bp.Parent = Ball

    -- ⚡ força de impacto (fica zerada até bater)
    local bv = Instance.new("BodyVelocity")
    bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    bv.Velocity = Vector3.zero
    bv.Parent = Ball

    -- 🌪️ rotação (ajuda no fling)
    local bav = Instance.new("BodyAngularVelocity")
    bav.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
    bav.AngularVelocity = Vector3.new(3000,3000,3000)
    bav.Parent = Ball

    -- 💥 DETECTOR DE TOQUE
    Ball.Touched:Connect(function(hit)
        local char = hit.Parent
        if char and char ~= character and char:FindFirstChild("HumanoidRootPart") then
            -- impulso absurdo no contato
            local dir = (hit.Position - Ball.Position).Unit
            bv.Velocity = dir * 2500 + Vector3.new(0,1500,0)

            -- reset rápido pra não ficar bugado
            task.delay(0.15, function()
                if bv then
                    bv.Velocity = Vector3.zero
                end
            end)
        end
    end)

    -- 🌀 órbita limpa
    local running = true
    local t = 0
    local radius = 6
    local speed = 2 -- velocidade CONTROLADA

    stopOrbit = function()
        running = false
        if bp then bp:Destroy() end
        if bv then bv:Destroy() end
        if bav then bav:Destroy() end
    end

    local connection
    connection = RunService.Heartbeat:Connect(function(dt)
        if not running or not hrp.Parent then
            connection:Disconnect()
            stopOrbit()
            return
        end

        t += dt * speed

        local x = math.cos(t) * radius
        local z = math.sin(t) * radius
        local y = 1.5 + math.sin(t*2)

        bp.Position = hrp.Position + Vector3.new(x,y,z)
    end)
end

